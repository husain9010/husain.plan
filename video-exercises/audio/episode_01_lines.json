[
  {"id": "01", "t": "00:00.0", "voice": "ar", "text": "الحلقة الأولى. اليوم نتمرّن على Listen and Repeat."},
  {"id": "02", "t": "00:03.5", "voice": "ar", "text": "خذ نفسًا، وركّز."},
  {"id": "03", "t": "00:05.0", "voice": "ar", "text": "هذا السؤال يقيس ثلاث مهارات."},
  {"id": "04", "t": "00:07.5", "voice": "ar", "text": "أولًا، وضوح النطق."},
  {"id": "05", "t": "00:10.0", "voice": "ar", "text": "ثانيًا، النبر والإيقاع."},
  {"id": "06", "t": "00:12.5", "voice": "ar", "text": "ثالثًا، وصل الكلمات."},
  {"id": "07", "t": "00:15.0", "voice": "ar", "text": "اسمع السؤال."},
  {"id": "08", "t": "00:16.5", "voice": "en", "text": "Despite the heavy rain, the match continued without any interruption."},
  {"id": "09", "t": "00:22.0", "voice": "en", "text": "Despite the heavy rain, the match continued without any interruption."},
  {"id": "10", "t": "00:28.0", "voice": "ar", "text": "جاهز؟"},
  {"id": "11", "t": "00:30.0", "voice": "ar", "text": "دورك الآن. لا توقف التسجيل."},
  {"id": "12", "t": "00:45.0", "voice": "ar", "text": "هذا الجواب النموذجي. ركّز على الإيقاع."},
  {"id": "13", "t": "00:48.0", "voice": "en", "text": "Despite the heavy rain,"},
  {"id": "14", "t": "00:58.0", "voice": "en", "text": "the match continued"},
  {"id": "15", "t": "01:08.0", "voice": "en", "text": "without any interruption."},
  {"id": "16", "t": "01:18.0", "voice": "ar", "text": "لاحظ كيف ينزل الصوت في نهاية كل مجموعة."},
  {"id": "17", "t": "01:30.0", "voice": "ar", "text": "لماذا يعمل هذا الجواب؟"},
  {"id": "18", "t": "01:33.0", "voice": "ar", "text": "النبر يقع دائمًا على الكلمات الحاملة للمعنى."},
  {"id": "19", "t": "01:38.0", "voice": "en", "text": "HEAV-y. RAIN. MATCH. con-TIN-ued. in-ter-RUP-tion."},
  {"id": "20", "t": "01:48.0", "voice": "ar", "text": "والحروف الساكنة تتصل بالحرف المتحرك الذي يليها."},
  {"id": "21", "t": "01:55.0", "voice": "en", "text": "heavy-rain. match-continued. without-any."},
  {"id": "22", "t": "02:05.0", "voice": "ar", "text": "تدرّب على هذه الجملة خمس مرات قبل أن تنتقل."},
  {"id": "23", "t": "02:30.0", "voice": "ar", "text": "القاعدة الذهبية اليوم:"},
  {"id": "24", "t": "02:32.5", "voice": "en", "text": "Stress the meaning words. Let the function words shrink."},
  {"id": "25", "t": "02:45.0", "voice": "ar", "text": "تمرّن يوميًا على practisEN.com."},
  {"id": "26", "t": "02:49.0", "voice": "ar", "text": "في الحلقة القادمة: Read Aloud تحت الضغط."},
  {"id": "27", "t": "02:55.0", "voice": "ar", "text": "إلى اللقاء."}
