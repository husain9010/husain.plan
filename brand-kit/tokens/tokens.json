{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": {
    "name": "practisEN",
    "tagline": "English, practised daily.",
    "version": "1.0.0"
  },
  "color": {
    "brand": {
      "primary":   { "value": "#7030E0", "description": "Violet 500 — primary brand color, used for CTAs, key accents" },
      "primaryDark": { "value": "#5B23BE", "description": "Violet 600 — hover / pressed state" },
      "ink":       { "value": "#0B0B1E", "description": "Deep navy — body text, headings on light" },
      "accent":    { "value": "#A78BFA", "description": "Violet 300 — highlight / illustrative accent" }
    },
    "navy": {
      "50":  "#F1F2F8",
      "100": "#DFE1EF",
      "200": "#BFC2DE",
      "300": "#8C92C1",
      "400": "#5962A0",
      "500": "#2F3984",
      "600": "#1F2971",
      "700": "#17205C",
      "800": "#0F1847",
      "900": "#0A1035"
    },
    "violet": {
      "50":  "#F4EFFF",
      "100": "#E7DBFF",
      "200": "#CDB4FF",
      "300": "#A78BFA",
      "400": "#8B5FF0",
      "500": "#7030E0",
      "600": "#5B23BE",
      "700": "#461A94",
      "800": "#35126E",
      "900": "#240B4B"
    },
    "ink": {
      "1": { "value": "#0B0B1E", "description": "Primary text" },
      "2": { "value": "#3A3A55", "description": "Secondary text" },
      "3": { "value": "#6B6B85", "description": "Tertiary / meta" },
      "4": { "value": "#9C9CB3", "description": "Disabled / placeholder" }
    },
    "surface": {
      "bg":     { "value": "#FAFAFC", "description": "Page background" },
      "bg2":    { "value": "#F3F2F8", "description": "Subtle alt surface" },
      "card":   { "value": "#FFFFFF", "description": "Card / elevated surface" },
      "line":   { "value": "#E5E4EE", "description": "Borders, dividers" },
      "line2":  { "value": "#EFEEF4", "description": "Subtle divider" }
    },
    "semantic": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error":   "#EF4444",
      "info":    "#7030E0"
    }
  },
  "typography": {
    "family": {
      "display": { "value": "'Baloo 2', system-ui, sans-serif", "description": "Rounded display — headings, hooks, logo" },
      "body":    { "value": "'Nunito', system-ui, sans-serif", "description": "Humanist body — paragraphs, UI" },
      "mono":    { "value": "'JetBrains Mono', ui-monospace, monospace", "description": "Code, eyebrows, meta labels" }
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "size": {
      "xs":   "12px",
      "sm":   "13.5px",
      "base": "15px",
      "md":   "17px",
      "lg":   "19px",
      "xl":   "24px",
      "2xl":  "32px",
      "3xl":  "44px",
      "4xl":  "56px",
      "5xl":  "72px",
      "6xl":  "96px"
    },
    "lineHeight": {
      "tight":   1.05,
      "snug":    1.15,
      "normal":  1.4,
      "relaxed": 1.55,
      "loose":   1.7
    },
    "letterSpacing": {
      "tightest": "-0.02em",
      "tight":    "-0.01em",
      "normal":   "0",
      "wide":     "0.02em",
      "wider":    "0.08em",
      "widest":   "0.15em"
    }
  },
  "radius": {
    "sm":   "6px",
    "md":   "10px",
    "lg":   "14px",
    "xl":   "20px",
    "2xl":  "28px",
    "pill": "999px"
  },
  "shadow": {
    "sm":  "0 1px 2px rgba(15, 24, 71, 0.06)",
    "md":  "0 4px 12px rgba(15, 24, 71, 0.08)",
    "lg":  "0 12px 32px rgba(15, 24, 71, 0.10)",
    "xl":  "0 24px 56px rgba(15, 24, 71, 0.14)",
    "brand": "0 8px 32px rgba(112, 48, 224, 0.25)"
  },
  "spacing": {
    "0":  "0",
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "motion": {
    "duration": {
      "fast":   "160ms",
      "base":   "240ms",
      "slow":   "320ms",
      "slower": "480ms"
    },
    "easing": {
      "standard": "cubic-bezier(.2, .8, .2, 1)",
      "in":       "cubic-bezier(.4, 0, 1, 1)",
      "out":      "cubic-bezier(0, 0, .2, 1)",
      "inOut":    "cubic-bezier(.4, 0, .2, 1)"
    }
  },
  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  }
}
